#include<iostream>
using namespace std;
class RBI
{
		public:
		virtual void dis()=0;	
};
class SBI:public RBI
{
	public:
		void dis()
		{
			cout<<"8.5"<<endl;
		}
};
class BOI:public RBI
{
	public:
		void dis()
		{
			cout<<"8.2"<<endl;
		}
};
main()
{
	SBI sbi=SBI();
	BOI boi=BOI();
	
	sbi.dis();
	boi.dis();
}
/*
output:
8.5
8.2
*/
