         select*from student where name like "a%";
        {ye jis bhi name ke suru mai (a) ata hoga vo sabhi dikhaye ga}


        select*from student where name like "%a";
        {ye jis bhi name ke last mai (a) ata hoga vo sabhi dikhaye ga}


        select*from student where name like "_a%";
