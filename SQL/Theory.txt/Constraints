7) foreign key:
-> this is a most power full topic of constraint and sql language using of foreign key we can build 
    relationship between two tables

    A parent ->  k child 
    B parent ->  j child

   (pk)  parent                            (pk)        child         (fk)
   ____________________________________________________________________________
    id   p_name                     |       id      c_name      p_name(p_id)
   ----------------------------------------------------------------------------
    1    A                          |       1        K              1
    2    B                          |       2        J              2
    3    C                          |       3        P              1
                                    |       4        O              3

    e.g.

    =-> create table parent(id int auto_increment primary key,name varchar(20),city varchar(30));
     =-> desc parent;
        +-------+-------------+------+-----+---------+----------------+
        | Field | Type        | Null | Key | Default | Extra          |
        +-------+-------------+------+-----+---------+----------------+
        | id    | int         | NO   | PRI | NULL    | auto_increment |
        | name  | varchar(20) | YES  |     | NULL    |                |
        | city  | varchar(30) | YES  |     | NULL    |                |
        +-------+-------------+------+-----+---------+----------------+
      =-> insert into parent(name,city) values ('PARENT_1','AHMEDABAD'),
             ('PARENT_2','SURAT'),
             ('PARENT_3','GOA'),
             ('PARENT_4','MUMBAI');
        =-> SELECT * FROM PARENT;
            +----+----------+-----------+
            | id | name     | city      |
            +----+----------+-----------+
            |  1 | PARENT_1 | AHMEDABAD |
            |  2 | PARENT_2 | SURAT     |
            |  3 | PARENT_3 | GOA       |
            |  4 | PARENT_4 | MUMBAI    |
            +----+----------+-----------+

            ((((now adding foreign key))))

->  create table child
         (id int auto_increment primary key,C_name varchar(20),p_id int,
         constraint fk_pid foreign key(p_id) references parent(id)
         on delete cascade
         on update cascade);
         {constraint nesesary hai ye bas erorr pe likha huva aye ga}

    =-> desc child;
        +--------+-------------+------+-----+---------+----------------+
        | Field  | Type        | Null | Key | Default | Extra          |
        +--------+-------------+------+-----+---------+----------------+
        | id     | int         | NO   | PRI | NULL    | auto_increment |
        | C_name | varchar(20) | YES  |     | NULL    |                |
        | p_id   | int         | YES  | MUL | NULL    |                |(MUL means foreign key)
        +--------+-------------+------+-----+---------+----------------+

    =-> insert into child(c_name,p_id)values('aaa',2),('bbb',1),('ccc',1);
    =-> select*from child;
            +----+--------+------+
