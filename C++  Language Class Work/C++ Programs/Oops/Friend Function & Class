#include<iostream>
using namespace std;
class Semple
{
	private:
		int score;
	public:
		Semple(int score)
		{
			this->score=score;
		}
			
		friend int display(Semple obj);
};
int display(Semple obj)
{
	cout<<"score ="<<obj.score<<endl;
}
main()
{
	Semple obj=Semple(97);
	display(obj);
}
/*
output:
score =97
*/
