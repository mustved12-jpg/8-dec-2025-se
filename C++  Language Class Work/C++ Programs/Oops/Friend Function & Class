#include<iostream>
using namespace std;
class B;
class A
{
	private:
		float record;
		
		public:
			A(float record)
			{
				this->record=record;
			}
			void just()
			{
				cout<<"\nok"<<endl;
			}
			friend B;
};
class B
{
	public:
		void display(A obj)
		{
			cout<<"record ="<<obj.record;
			obj.just();
		}
		
};
main()
{
	A a=A(67.324);
	B b=B();
	b.display(a);
}
/*
output:
record =67.324
ok
*/