#~~~ Write a Python program to handle exceptions in a simple calculator (division by zero, invalid input).

number1=int(input("enter a number 1 :"))
number2=int(input("enter a number 2 :"))

try:
    print("answer =",number1//number2)
except ZeroDivisionError as e:
    print(e,"not allowed!!!")


#~~~ Write a Python program to demonstrate handling multiple exceptions.

try:
    number1=int(input("enter a number 1 :"))
    number2=int(input("enter a number 2 :"))
    print("answer =",number1//number2)
except ZeroDivisionError as e:
    print(e,"not allowed!!!")
except ValueError as e:
    print("enter a integer number only!!!")
except:
    print("somting went wrong!!!")

#~~~ Write a Python program to handle file exceptions and use the finally block for closing the file. 

try:
    with open("hello.text",'r') as f:
        data=f.read()
        print(data)
except FileNotFoundError:
    print("file not found!!!")
except Exception as e:
    print(e)
finally:
    print("thak you for comming...")


