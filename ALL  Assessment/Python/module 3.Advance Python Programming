# Write a Python program to connect to an SQLite3 database, create a table, insert data, and fetch data.
import sqlite3
import os
if not os.path.exists("school.db"):
    with open("school.db",'x'):
        print("file created successfully..")

sql=sqlite3.connect("school.db")
hat=sql.cursor()
hat.execute("create table if not exists student (id int not null,name text,subject varchar(20) default 'python')")
hat.execute("insert into student (id,name)values(3,'aaa'),(4,'ddd')")
hat.execute("select * from student")
data=hat.fetchall()
print(data)
sql.commit()

