# Write Python programs to demonstrate method overloading and method overriding
# python me method overloading sport nhi karti hai
# method overriding
class A:
    def d(self):
        print('parent class')
class B(A):
    def d(self):
        super().d()
        # or
        A.d(self)
        print("child class")
obj=B()
obj.d()

