# Objective
# Build a console-based Student Productivity Tracker that logs daily study hours and
# generates a weekly report.
# Your application must:
# 1. Menu-driven program
# 2. Log daily study hours
# 3. Generate weekly report
# 4. Store data using files


import os
def hours():
    day=input("enter day : ")
    hours=float(input("enter your todays houres :"))
    with open("Student Productivity Tracker.txt",'a') as f:
        f.write(f"{day} : {hours}\n")
    print("study hours added successuly!")

def weekly():
    if os.path.exists("Student Productivity Tracker.txt"):
        with open("Student Productivity Tracker.txt",'r') as f:
            for i in f.readlines():
                print(i,end="")
    else:
        print("file not found!!")
        # return
while 1:
    menu=int(input("""
                :MENU:
            press 1 for daly study hours
            press 2 for weekly report
            press 3 for exit menu
        
    enter your choice :""".title()))
    if menu==1:
        hours()
    elif menu==2:
        weekly()
    else:
        break